# ─────────────────────────────────────────────────────────────────────────────
# Kurdistan Air Watch — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# In Vercel: Dashboard -> Project -> Settings -> Environment Variables
# For local `vercel dev`: copy to .env.local and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenSky Network credentials ───────────────────────────────────────────────
# Used by api/opensky.js — never exposed to the browser.
# Optional: anonymous access works but is heavily rate-limited (~400 req/day).
# Register free at https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
