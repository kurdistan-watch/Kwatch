# ─── OpenSky API credentials ──────────────────────────────────────────────────
# Used by the Vercel serverless functions (api/opensky.js) — never sent to browser.
# For Vercel production: set in Dashboard → Project Settings → Environment Variables
# For local `vercel dev`: copy this file to .env and fill in values.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=